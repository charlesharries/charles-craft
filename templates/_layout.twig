<!DOCTYPE html>
<html lang="{{ craft.app.language }}" style="--primary: {{ percentThroughDay() * 360 }}">
	<head>
		<meta charset="utf-8"/>
		<title>
			{% block title %}{% endblock %}
			&bull;
			{{ siteName }}
		</title>
		<meta content="width=device-width, initial-scale=1.0" name="viewport">
		<link href="/style.css?v={|{VERSION}|}" rel="stylesheet"/>
		<link href="/hljs.css?v={|{VERSION}|}" rel="stylesheet"/>
		<link href="/animatedname.css?v={|{VERSION}|}" rel="stylesheet" />

		<link rel="apple-touch-icon" sizes="180x180" href="/images/favicon"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon"/>
		<link rel="mask-icon" href="/images/safari-pinned-tab.svg" color="#222222"/>
		<link rel="shortcut icon" href="/images/favicon"/>
		<link rel="alternate" type="application/rss+xml" href="/feed.xml" title="RSS Feed"/>
		<link rel="webmention" href="https://webmention.io/charlesharri.es/webmention"/>
		<link rel="pingback" href="https://webmention.io/charlesharri.es/xmlrpc"/>

		{# Extra head tags per page #}
		{% block head %}{% endblock %}
	</head>

	<body class="ltr">
		<header class="container">
			<nav class="flex justify-between align-start">
				<a href="/" aria-label="Charles Harries" class="no-decoration">
					{% include "_partials/animatedname.twig" %}
				</a>

				<ul role="list" class="cluster">
					<li>
						<a href="/about">About</a>
					</li>
					<li>
						<button id="theme-toggle"></button>
					</li>
				</ul>
			</nav>
		</header>

		{% block content %}{% endblock %}

		<footer class="container mt-lg">
			<hr class="mt-lg"/>
			<div class="footer mt-md">
				<div>
					{% include "_partials/latesttrack.twig" %}
				</div>
				<div class="footer_right">
					<p class="caps">
						<small>Elsewhere on the web</small>
					</p>
					<ul role="list" class="cluster mt-sm">
						<li>
							<a href="https://github.com/charlesharries" rel="me">Github</a>
						</li>
						<li>
							<a rel="me" href="https://mastodon.social/@charlesharries">Mastodon</a>
						</li>
						<li>
							<a href="https://letterboxd.com/charlesharries/" rel="me">Letterboxd</a>
						</li>
						<li>
							<span class="darkish">&bull;</span>
						</li>
						<li>
							<a href="https://charlesharri.es/feed.xml">RSS</a>
						</li>
					</ul>
				</div>
			</div>
		</footer>

		<div id="lightbox"></div>

		<script src="/js/darkmode.js" type="text/javascript"></script>
		<script src="/js/latesttrack.js" type="text/javascript"></script>
		<script src="/js/lightbox.js" type="text/javascript"></script>

		{% if not craft.app.config.general.devMode %}
			<script async defer data-website-id="f163f9d6-58e1-41f2-bc17-e99d4e76e8d8" src="https://stats.charlesharri.es/umami.js"/>
		{% endif %}
	</body>
</html>
