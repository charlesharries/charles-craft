<!DOCTYPE html>
<html lang="{{ craft.app.language }}" style="--primary: {{ percentThroughDay() * 360 }}">
	<head>
		<meta charset="utf-8"/>
		<title>
			{% block title %}{% endblock %} - {{ siteName }}
		</title>
		<meta content="width=device-width, initial-scale=1.0" name="viewport">
		<link href="/style.css?v={|{VERSION}|}" rel="stylesheet"/>
		<link href="/hljs.css?v={|{VERSION}|}" rel="stylesheet"/>
		<link href="/animatedname.css?v={|{VERSION}|}" rel="stylesheet" />

		<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-icon-180x180.png"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png"/>
		<link rel="icon" type="image/png" sizes="96x96" href="/icons/favicon-96x96.png">
		<link rel="mask-icon" href="/images/safari-pinned-tab.svg" color="#222222"/>
		<link rel="shortcut icon" href="/icons/favicon.ico"/>
		<link rel="manifest" href="/manifest.json">
		<link rel="alternate" type="application/rss+xml" href="/feed.xml" title="RSS Feed"/>
		<link rel="webmention" href="https://webmention.io/charlesharri.es/webmention"/>
		<link rel="pingback" href="https://webmention.io/charlesharri.es/xmlrpc"/>
		<link rel="canonical" href="{{ craft.app.request.absoluteURL }}">

		<style>
			::backdrop {
				--primary: {{ percentThroughDay() * 360 }};
			}

			.bw ::backdrop {
				--saturation: 0%;
			}

			.light ::backdrop { --lightness: 80%; }
		</style>

		{# Extra head tags per page #}
		{% block head %}{% endblock %}
	</head>

	<body class="ltr">
		<header class="container">
			<nav class="flex justify-between align-start">
				<a href="/" aria-label="Charles Harries" class="no-decoration nostyle">
					{% include "_partials/animatedname.twig" %}
				</a>

				<ul role="list" class="cluster">
					{% if currentUser %}
						<li><a href="/admin/entries" class="sans">Control Panel</a></li>
					{% endif %}
					<li>
						<a href="/about">About</a>
					</li>
					<li>
						<button id="theme-toggle"></button>
					</li>
					<li>
						<button id="color-theme-toggle"></button>
					</li>
				</ul>
			</nav>
		</header>

		{% block content %}{% endblock %}

		<footer class="container mt-lg">
			<hr class="mt-lg"/>
			<div class="footer mt-md">
				<div>
					{% include "_partials/latesttrack.twig" %}
				</div>
				<div class="footer_right">
					<p class="sans">
						<small>Elsewhere on the web</small>
					</p>
					<ul role="list" class="cluster mt-sm">
						<li>
							<a href="https://github.com/charlesharries" rel="me">Github</a>
						</li>
						<li>
							<a rel="me" href="https://mastodon.social/@charlesharries">Mastodon</a>
						</li>
						<li>
							<a href="https://letterboxd.com/charlesharries/" rel="me">Letterboxd</a>
						</li>
						<li>
							<span class="darkish">&bull;</span>
						</li>
						<li>
							<a href="https://charlesharri.es/feed.xml">RSS</a>
						</li>
					</ul>
				</div>
			</div>
		</footer>

		<div id="lightbox"></div>

		<dialog id="search">
			<form action="/api/search" method="GET" id="searchForm">
				{{ csrfInput() }}
				<input id="searchQuery" name="searchQuery" type="text" placeholder="Search for a post..." />
			</form>

			<template id="searchResult">
				<li>
					<a class="searchResult_link" href="#">
						<p class="searchResult_date text-sm muted sans"></p>
						<h2 class="searchResult_title text-md"></h2>
						{# <p class="searchResult_body text-sm mt-sm"></p> #}
					</a>
				</li>
			</template>
		</dialog>

		<script src="/js/eventbus.js?v={|{VERSION}|}" type="text/javascript"></script>
		<script src="/js/darkmode.js?v={|{VERSION}|}" type="text/javascript"></script>
		<script src="/js/colormode.js?v={|{VERSION}|}" type="text/javascript"></script>
		<script src="/js/latesttrack.js" type="text/javascript"></script>
		<script src="/js/lightbox.js" type="text/javascript"></script>
		<script src="/js/search.js?v={|{VERSION}|}" type="text/javascript"></script>
		<script src="/js/loadall.js?v={|{VERSION}|}" type="text/javascript"></script>

		{{ trackPageview() }}
	</body>
</html>
