<!DOCTYPE html>
<html lang="{{ craft.app.language }}" style="--primary: {{ percentThroughDay() * 360 }}">
	<head>
		<meta charset="utf-8"/>
		<title>
			{% block title %}{% endblock %}
			&bull;
			{{ siteName }}
		</title>
		<meta content="width=device-width, initial-scale=1.0" name="viewport">
		<link href="/style.css?v={|{VERSION}|}" rel="stylesheet"/>
		<link href="/hljs.css?v={|{VERSION}|}" rel="stylesheet"/>

		<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-icon-180x180.png"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png"/>
		<link rel="mask-icon" href="/images/safari-pinned-tab.svg" color="#222222"/>
		<link rel="shortcut icon" href="/images/favicon.ico"/>

		{# Extra head tags per page #}
		{% block head %}{% endblock %}
	</head>

	<body class="ltr">
		<header class="container">
			<nav class="flex justify-between">
				<ul role="list" class="cluster">
					<li>
						<a href="/">Home</a>
					</li>
					<li>
						<a href="/about">About</a>
					</li>
				</ul>

				<button id="theme-toggle"></button>
			</nav>
		</header>

		{% block content %}{% endblock %}

		<footer class="container mt-lg">
			<hr class="mt-lg"/>
			<div class="footer mt-md">
				<div>
					{% include "_partials/latesttrack.twig" %}
				</div>
				<div class="footer_right">
					<p class="caps">
						<small>Elsewhere on the web</small>
					</p>
					<ul role="list" class="cluster mt-sm">
						<li>
							<a href="https://github.com/charlesharries">Github</a>
						</li>
						<li>
							<a href="https://twitter.com/charlesharries">Twitter</a>
						</li>
						<li>
							<a href="https://letterboxd.com/charlesharries/">Letterboxd</a>
						</li>
						<li>
							<span class="darkish">&bull;</span>
						</li>
						<li>
							<a href="https://charlesharri.es/feed.xml">RSS</a>
						</li>
					</ul>
				</div>
			</div>
		</footer>

		<script src="/js/darkmode.js" type="text/javascript"></script>
		<script src="/js/latesttrack.js" type="text/javascript"></script>

		{% if not craft.config.devMode %}
			<script async defer data-website-id="f163f9d6-58e1-41f2-bc17-e99d4e76e8d8"
				src="https://stats.charlesharri.es/umami.js" />
		{% endif %}
	</body>
</html>
