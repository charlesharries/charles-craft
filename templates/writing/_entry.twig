{% extends "_layout.twig" %}

{% block title %}
	{{ entry.title }}
{% endblock %}

{% block head %}
	{%- set title = entry.title -%}
	{%- set description = entry.summary -%}
	{%- set image = url(url() ~ "api/post-images/" ~ entry.slug ~ ".jpeg") -%}
	{%- set url = url() -%}
	<meta property="og:description" content="{{ description }}"/>
	<meta property="og:image" content="{{ image }}"/>
	<meta property="og:locale" content="en_GB"/>
	<meta property="og:site_name" content="{{ title }}"/>
	<meta property="og:title" content="{{ title }}"/>
	<meta property="og:type" content="website"/>
	<meta property="og:url" content="{{ url }}"/>
	<meta name="twitter:card" content="summary_large_image"/>
	<meta name="twitter:site" content="{{ url }}"/>
	<meta name="twitter:title" content="{{ title }}"/>
	<meta name="twitter:description" content="{{ description }}"/>
	<meta name="twitter:creator" content="@charlesharries"/>
	<meta name="twitter:image:src" content="{{ image }}"/>
{% endblock %}

{% block content %}
	<main class="entry container mt-lg">
		<small class="lightish">
			{% include "_partials/postmeta.twig" with {'entry': entry} only %}
		</small>

		<h1 class="mt-xs">{{ entry.title }}</h1>

		{% if entry.section == "Books" %}
			<div class="mt-xs">
				{% include "_partials/bookmeta.twig" with {'entry': entry} only %}
			</div>
		{% endif %}

		<div class="stack mt-sm">
			{{ entry.body|syntaxHighlight }}
		</div>
	</main>
{% endblock content %}
