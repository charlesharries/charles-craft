<article class="{{ entry.section }}">
	<small class="lightish">
		<time>{{ entry.postDate|date("d M Y g:i a") }}</time>
		{% if entry.tags.exists() %}
			|
			{{ entry.tags.all()|join(', ')}}
		{% endif %}
	</small>
	<h2 class="{{ entry.section == "Posts" ? "text-xl" : "" }}">
		<a href="/writing/{{ entry.slug }}">
			{{ entry.title }}
		</a>
	</h2>

	{% if entry.section == "Stream" %}
		<div class="mt-sm stack">
			{{ entry.body }}
		</div>
	{% else %}
		<div class="mt-sm">
			<div class="text-lg">
				{{ entry.summary }}
			</div>
		</div>
	{% endif %}
</article>
