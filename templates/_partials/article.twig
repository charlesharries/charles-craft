<article class="{{ entry.section }}">
	<small class="lightish">
		{% include "_partials/postmeta.twig" with {'entry': entry} only %}
	</small>
	<h2 class="{{ entry.section == "Posts" ? "text-xl" : "" }} mt-xs">
		<a href="/writing/{{ entry.slug }}">
			{{ entry.title }}
		</a>
	</h2>

	{% if entry.section == "Stream" %}
		<div class="mt-sm stack">
			{{ entry.body|syntaxHighlight }}
		</div>
	{% else %}
		<div class="mt-sm">
			{% if entry.section == "Books" %}
				{% include "_partials/bookmeta.twig" with {'entry': entry} only %}
			{% endif %}

			<div class="text-lg">
				{{ entry.summary|syntaxHighlight }}
			</div>
		</div>
	{% endif %}
</article>
