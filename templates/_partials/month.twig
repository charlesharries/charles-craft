{%- set streamItems = entries|filter((e) => e.section == 'Stream') -%}
{%- set theRest = entries|filter((e) => e.section != "Stream") -%}

{%- set icons = {'walks': '👟', 'books': '📚'} -%}

<div class="month">
	<h4 class="sans muted mt-md regular">
		{{ month }}
		{{ year }}
	</h4>
	<ol role="list" class="month_items mt-sm">
		{% for entry in entries %}
			<li>
				<a href="{{ entry.url }}" class="flex justify-between no-decoration">
					<span class="underline flex align-center">
						<span>
							{% if icons[entry.section.handle] is defined %}
								<span class="mr-xs">{{ icons[entry.section.handle] }}</span>
							{% endif %}
							{{ entry.title }}
						</span>
						{% if entry.rating %}
							<span class="ml-sm muted">
								{% include "_partials/stars" with {'count': entry.rating} only %}
							</span>
						{% endif %}
					</span>
					<hr class="dots flex-1"/>
					<span class="underline">{{ entry.postDate|date("j") }}</span>
				</a>
				{% if entry.section.handle == 'posts' %}
					<p class="text-sm ml-sm mt-xs muted sans italic">{{ entry.summary }}</p>
				{% endif %}
			</li>
		{% endfor %}
	</ol>
</div>
