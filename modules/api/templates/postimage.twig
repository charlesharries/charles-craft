{% set hour = entry.postDate|date('G') + 0 %}
{% set isDark = hour >= 19 or hour < 7 %}

{% set primary = 97 %}
{% set highlightH = isDark ? 43 : 226 %}
{% set background = isDark ? 'hsl(' ~ primary ~ ', 80%, 5%)' : 'hsl(' ~ primary ~ ', 20%, 95%)' %}
{% set text = isDark ? 'hsl(' ~ primary ~ ', 20%, 95%)' : 'hsl(' ~ primary ~ ', 80%, 5%)' %}
{% set muted = isDark ? 'hsl(' ~ primary ~ ', 30%, 70%)' : 'hsl(' ~ primary ~ ', 40%, 15%)' %}
{% set accent = 'hsla(' ~ highlightH ~ ', 100%, 50%, 0.99)' %}

{% set type = entry.section.name %}
{% set tagNames = entry.tags.all()|map(tag => tag.title) %}

{% set fontsPath = 'file://' ~ alias('@webroot') ~ '/fonts' %}

<html>
	<head>
		<style>
			@font-face {
				font-family: 'Bitter';
				src: url('{{ fontsPath }}/Bitter-Regular.woff2') format('woff2');
				font-weight: 400;
				font-style: normal;
			}
			@font-face {
				font-family: 'Bitter';
				src: url('{{ fontsPath }}/Bitter-Bold.woff2') format('woff2');
				font-weight: 700;
				font-style: normal;
			}
			@font-face {
				font-family: 'Bitter';
				src: url('{{ fontsPath }}/Bitter-Italic.woff2') format('woff2');
				font-weight: 400;
				font-style: italic;
			}
			@font-face {
				font-family: 'Fira Sans';
				src: url('{{ fontsPath }}/FiraSans-Regular.woff2') format('woff2');
				font-weight: 400;
				font-style: normal;
			}
			@font-face {
				font-family: 'Fira Sans';
				src: url('{{ fontsPath }}/FiraSans-Italic.woff2') format('woff2');
				font-weight: 400;
				font-style: italic;
			}

			* {
				margin: 0;
				box-sizing: border-box;
			}

			body {
				font-family: 'Bitter', Georgia, serif;
				background: {{ background }};
				color: {{ text }};
			}

			.container {
				width: 1200px;
				height: 630px;
				padding: 80px 90px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}

			.eyebrow {
				font-family: 'Fira Sans', sans-serif;
				font-style: italic;
				font-size: 36px;
				color: {{ accent }};
				letter-spacing: -0.01em;
				text-transform: lowercase;
			}

			.eyebrow .divider {
				margin: 0 0.5em;
				opacity: 0.6;
			}

			.title {
				font-family: 'Fira Sans', sans-serif;
				font-style: italic;
				font-weight: 400;
				font-size: 96px;
				line-height: 1.05;
				letter-spacing: -0.03em;
				margin-top: 24px;
				color: {{ text }};
			}

			.summary {
				font-family: 'Bitter', Georgia, serif;
				font-size: 34px;
				line-height: 1.4;
				margin-top: 32px;
				color: {{ muted }};
				max-width: 900px;
			}

			.footer {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				font-family: 'Fira Sans', sans-serif;
				font-size: 28px;
				color: {{ muted }};
			}

			.footer .url {
				font-style: italic;
			}

			.footer .date {
				letter-spacing: 0.02em;
			}
		</style>
	</head>

	<body>
		<div class="container">
			<div>
				<p class="eyebrow">
					<span class="type">{{ type }}</span>
					{% if tagNames|length %}
						<span class="divider">|</span>
						<span class="tags">{{ tagNames|join(', ') }}</span>
					{% endif %}
				</p>
				<h1 class="title">{{ entry.title }}</h1>
				{% if entry.summary %}
					<p class="summary">{{ entry.summary }}</p>
				{% endif %}
			</div>
			<div class="footer">
				<span class="url">charlesharri.es</span>
				<time class="date" datetime="{{ entry.postDate|date('Y-m-d') }}">
					{{ entry.postDate|date('j M Y') }}
				</time>
			</div>
		</div>
	</body>
</html>
